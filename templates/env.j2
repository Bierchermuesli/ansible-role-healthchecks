# Managed by Ansible — do not edit manually
ALLOWED_HOSTS={{ healthchecks_allowed_hosts }}
DEBUG={{ healthchecks_debug | capitalize }}
SECRET_KEY={{ healthchecks_secret_key }}

# Database
{% if healthchecks_db == 'postgres' %}
DB=postgres
DB_HOST={{ healthchecks_db_host }}
DB_PORT={{ healthchecks_db_port }}
DB_NAME={{ healthchecks_db_name }}
DB_USER={{ healthchecks_db_user }}
DB_PASSWORD={{ healthchecks_db_password }}
{% else %}
DB=sqlite3
{% endif %}

# Proxy
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https

# Site
SITE_ROOT={{ healthchecks_site_root }}
SITE_NAME={{ healthchecks_site_name }}
DEFAULT_FROM_EMAIL={{ healthchecks_default_from_email }}
PING_ENDPOINT={{ healthchecks_ping_endpoint }}
PING_EMAIL_DOMAIN={{ healthchecks_ping_email_domain }}
PING_BODY_LIMIT={{ healthchecks_ping_body_limit }}

# Email
EMAIL_HOST={{ healthchecks_email_host }}
EMAIL_PORT={{ healthchecks_email_port }}
EMAIL_USE_TLS={{ healthchecks_email_use_tls | capitalize }}
EMAIL_HOST_USER={{ healthchecks_email_host_user }}
EMAIL_HOST_PASSWORD={{ healthchecks_email_host_password }}
EMAIL_USE_VERIFICATION={{ healthchecks_email_use_verification | capitalize }}

# Registration
REGISTRATION_OPEN={{ healthchecks_registration_open | capitalize }}

# Integrations
APPRISE_ENABLED={{ healthchecks_apprise_enabled | capitalize }}
PROMETHEUS_ENABLED={{ healthchecks_prometheus_enabled | capitalize }}
WEBHOOKS_ENABLED={{ healthchecks_webhooks_enabled | capitalize }}
SHELL_ENABLED={{ healthchecks_shell_enabled | capitalize }}
INTEGRATIONS_ALLOW_PRIVATE_IPS={{ healthchecks_integrations_allow_private_ips | capitalize }}
